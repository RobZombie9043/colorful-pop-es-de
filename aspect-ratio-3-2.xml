<!-- 
3:2 aspect ratio
-->
<theme>
	<view name="system">
		<text name="system-year">
			<fontSize>0.055</fontSize>
		</text>
		<text name="systemName, autoCollectionName, customCollectionName">
			<fontSize>0.062</fontSize>
		</text>
		<text name="system-description">
			<pos>0.0260416 0.4725</pos>	
			<size>0.3070624 0.22</size>
		</text>
	</view>
	
	<!--
	///
	Gamelist View: List
	///
	-->
	<variant name="list, list-monochrome">
		<view name="gamelist">
			<text name="game-players">
				<pos>0.9375 0.3157407</pos>
			</text>
		</view>
	</variant>
	
	<!--
	///
	Gamelist View: Carousel
	///
	-->
	<variant name="carousel, carousel-monochrome">
		<view name="gamelist">
			<datetime name="game-release-date">
				<pos>0.065 0.835</pos>
			</datetime>
			<image name="game-players-icon">
				<pos>0.155  0.835</pos>
			</image>
			<text name="game-players-label">
				<pos>0.193958334 0.835</pos>
			</text>
		</view>
	</variant>
</theme>