<themeCapabilities>
   
	<themeName>Colorful (Pop!)</themeName>

	<!--
	///
	Aspect Ratios
	///
	-->
	<aspectRatio>1:1</aspectRatio>
	<aspectRatio>5:4</aspectRatio>
	<aspectRatio>4:3</aspectRatio>
	<aspectRatio>3:2</aspectRatio>
	<aspectRatio>16:10</aspectRatio>
	<aspectRatio>16:9</aspectRatio>
	<aspectRatio>19.5:9</aspectRatio>
	<aspectRatio>21:9</aspectRatio>
	
	<!--
	///
	Font Sizes
	///
	-->
	<fontSize>medium</fontSize>
	<fontSize>small</fontSize>
	<fontSize>large</fontSize> 
	
	<!--
	///
	Transitions
	///
	-->
	<transitions name="transitions">
		<label>transitions</label>
		<selectable>false</selectable>
		<systemToSystem>instant</systemToSystem>
		<systemToGamelist>slide</systemToGamelist>
		<gamelistToGamelist>slide</gamelistToGamelist>
		<gamelistToSystem>slide</gamelistToSystem>
		<startupToSystem>fade</startupToSystem>
		<startupToGamelist>fade</startupToGamelist>
	</transitions>
	<suppressTransitionProfiles>
		<entry>builtin-instant</entry>
		<entry>builtin-slide</entry>
		<entry>builtin-fade</entry>
	</suppressTransitionProfiles>

	<!--
	///
	Color Schemes
	///
	-->
	<colorScheme name="light">
		<label>Light</label>
	</colorScheme>
	<colorScheme name="dark">
		<label>Dark</label>
	</colorScheme>
	<colorScheme name="black">
		<label>Black</label>
	</colorScheme>
	
	<!--
	///
	Variants
	///
	-->
	<variant name="list">
		<label>List - Colorful</label>
		<selectable>true</selectable>
	</variant>
	<variant name="list-monochrome">
		<label>List - Monochrome</label>
		<selectable>true</selectable>
	</variant>
	<variant name="carousel">
		<label>Carousel - Colorful</label>
		<selectable>true</selectable>
	</variant>
	<variant name="carousel-monochrome">
		<label>Carousel - Monochrome</label>
		<selectable>true</selectable>
	</variant>
   
</themeCapabilities>